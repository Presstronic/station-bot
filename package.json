{
  "name": "station-bot",
  "version": "0.3.2-beta.3",
  "description": "A Discord bot for verifying users against their roberts space industries profiles.",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json && cp -r src/locales dist/locales",
    "start": "NODE_ENV=production node dist/index.js",
    "lint": "tsc -p tsconfig.lint.json --noEmit",
    "test": "NODE_ENV=test node --experimental-vm-modules node_modules/.bin/jest --detectOpenHandles",
    "test:integration": "NODE_ENV=test node --experimental-vm-modules node_modules/.bin/jest --detectOpenHandles --testPathPattern='\\.integration\\.test\\.ts$' --runInBand",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "quality": "npm audit --audit-level=high && npm run lint && npm run typecheck && npm test -- --runInBand",
    "migrate:create": "node-pg-migrate create -m ./migrations --migration-file-language cjs",
    "migrate:up": "node-pg-migrate up -m ./migrations --database-url \"$DATABASE_URL\"",
    "migrate:down": "node-pg-migrate down -m ./migrations --database-url \"$DATABASE_URL\""
  },
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "author": "Demian",
  "license": "GPL-3.0",
  "dependencies": {
    "@elastic/elasticsearch": "^8.17.0",
    "axios": "^1.7.8",
    "cheerio": "^1.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.7",
    "i18n": "^0.15.1",
    "node-cron": "^3.0.3",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.19.0",
    "reflect-metadata": "^0.2.2",
    "tsx": "^4.19.2",
    "winston": "^3.17.0",
    "winston-elasticsearch": "^0.19.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/axios": "^0.9.36",
    "@types/elasticsearch": "^5.0.43",
    "@types/i18n": "^0.13.12",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.30",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.18.0",
    "@types/winston": "^2.4.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.2",
    "ts-jest-resolver": "^2.0.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Presstronic/station-bot.git"
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/Presstronic/station-bot/issues"
  },
  "homepage": "https://github.com/Presstronic/station-bot#readme",
  "overrides": {
    "undici": "6.24.1"
  }
}
